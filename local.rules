# Suricata custom detection rules for suspicious and malicious activity

# Detect potential SSH brute force scans
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"SURICATA SSH brute force attempt"; flow:established,to_server; threshold:type both, track by_src, count 5, seconds 60; sid:1000001; rev:1;)

# Detect potential SQL injection patterns in HTTP requests
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"SURICATA possible SQL injection"; flow:to_server,established; http.uri; pcre:"/\b(select|union|insert|delete|update|drop)\b/i"; classtype:web-application-attack; sid:1000002; rev:1;)

# Detect suspicious DNS requests for potentially malicious domains
alert dns $EXTERNAL_NET any -> $HOME_NET any (msg:"SURICATA suspicious DNS query"; dns_query; content:"malicious"; nocase; sid:1000003; rev:1;)

# Detect potential ICMP scanning
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"SURICATA ICMP scan"; icode:0; threshold:type both, track by_src, count 20, seconds 60; sid:1000004; rev:1;)

# Detect HTTP User-Agent strings used by common scanners
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"SURICATA scanner User-Agent detected"; flow:to_server,established; http.user_agent; pcre:"/^(?:curl|wget|nmap|masscan)/i"; sid:1000005; rev:1;)
